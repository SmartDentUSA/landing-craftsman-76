      "name": "1. Básicos",
      "item": [
        {
          "name": "Get Complete Knowledge Base (JSON)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}",
              "host": ["{{base_url}}"]
            },
            "description": "Retorna a base de conhecimento completa no formato JSON estruturado com todos os 250+ campos."
          }
        },
        {
          "name": "Get AI Training Format",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}?format=ai_training",
              "host": ["{{base_url}}"],
              "query": [
                {
                  "key": "format",
                  "value": "ai_training"
                }
              ]
            },
            "description": "Retorna a base de conhecimento em formato texto otimizado para treinar LLMs (GPT, Claude, etc)."
